                    00001           ;TPicSim300.src
                    00002           ;Testprogramm f³r reine Konsolenausgabe
                    00003           ;
                    00004           ;Stand: 18.05.2023
                    00005           ;
                    00006           ;Falls ein Einzelkõmpfer oder -kõmpferin keine GUI schafft 
                    00007           ;die Ausgabe auf der Konsole erfolgt, kann mit diesem Progr
                    00008           ;dennoch die Funktionalitõt der Simulation erfolgen.
                    00009           ;
                    00010           ;Trotzdem sollte eine M÷glichkeit vorhanden  sein, die es
                    00011           ;m÷glich macht, die Stimulation der Pins zu realisieren, z.
                    00012           ;durch Konsoleneingabe von 0-7 f³r Port B und SHIFT 0-7 f³r
                    00013           ;Port A. Diese Eingabe wird mit System.in realisiert. Wann 
                    00014           ;solche Eingabe erwartet wird, zeigt der Pseudo-Befehl INKE
                    00015           ;LST-File an. Der Pseudobefehl PRINT verbessert die Orienti
                    00016           ;in der Konsolenausgabe. In der Binõrcodierung wird der NOP
                    00017           ;erweitert. 
                    00018           ;Normaler NOP = 00 0000 0000 0000  (0x0000) 
                    00019           ;INKEY        = 00 0000 0010 0000  (0x0020)
                    00020           ;PRINT        = 00 0000 0100 0000  (0x0040)
                    00021           
                    00022           ;Definition des Prozessors
                    00023           device 16F84
